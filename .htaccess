<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # 1. Leave index.php alone
    RewriteRule ^index\.php$ - [L,END]

    # 2. Serve real files / directories directly (no rewrite needed)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L,END]

    # 3. Everything else → proxy into public/
    #    [L] (not END) lets public/.htaccess handle both static assets
    #    and Laravel routing — works whether the app is at the domain
    #    root (production) or inside a subdirectory (local MAMP).
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
